<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Root menu -->
    <menuitem id="menu_mcp_root"
              name="MCP AI Gateway"
              sequence="90"
              groups="mcp_ai_gateway.group_mcp_user"
              web_icon="mcp_ai_gateway,static/src/img/icon.png"/>

    <!-- Configuration sub-menu (managers only) -->
    <menuitem id="menu_mcp_config"
              name="Configuration"
              parent="menu_mcp_root"
              sequence="10"
              groups="mcp_ai_gateway.group_mcp_manager"/>

    <menuitem id="menu_mcp_provider"
              name="AI Providers"
              parent="menu_mcp_config"
              action="action_mcp_provider"
              sequence="10"/>

    <menuitem id="menu_mcp_tool"
              name="Tools"
              parent="menu_mcp_config"
              action="action_mcp_tool"
              sequence="20"/>

    <menuitem id="menu_mcp_api_key"
              name="API Keys"
              parent="menu_mcp_config"
              action="action_mcp_api_key"
              sequence="30"/>

    <!-- Operations (all users) -->
    <menuitem id="menu_mcp_ops"
              name="Operations"
              parent="menu_mcp_root"
              sequence="20"
              groups="mcp_ai_gateway.group_mcp_user"/>

    <menuitem id="menu_mcp_conversation"
              name="Conversation Log"
              parent="menu_mcp_ops"
              action="action_mcp_conversation"
              sequence="10"/>

    <menuitem id="menu_mcp_test"
              name="Test Wizard"
              parent="menu_mcp_ops"
              action="action_mcp_test_wizard"
              sequence="20"/>

</odoo>
