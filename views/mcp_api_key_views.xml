<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── List ── -->
    <record id="view_mcp_api_key_list" model="ir.ui.view">
        <field name="name">mcp.api.key.list</field>
        <field name="model">mcp.api.key</field>
        <field name="arch" type="xml">
            <list string="MCP API Keys" decoration-muted="not active">
                <field name="name"/>
                <field name="key_prefix" string="Key Prefix"/>
                <field name="user_id"/>
                <field name="total_requests"/>
                <field name="last_used"/>
                <field name="expires_at"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- ── Form ── -->
    <record id="view_mcp_api_key_form" model="ir.ui.view">
        <field name="name">mcp.api.key.form</field>
        <field name="model">mcp.api.key</field>
        <field name="arch" type="xml">
            <form string="MCP API Key">
                <header>
                    <button name="action_generate_key" type="object"
                            string="Generate New Key" class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <group string="Key Info">
                            <field name="name"/>
                            <field name="active"/>
                            <field name="key_prefix" readonly="1"/>
                            <field name="user_id"/>
                            <field name="expires_at"/>
                        </group>
                        <group string="Statistics">
                            <field name="total_requests"/>
                            <field name="last_used"/>
                        </group>
                    </group>
                    <group string="Permissions">
                        <field name="allowed_tools" widget="many2many_tags"
                               placeholder="Leave blank to allow all tools"/>
                        <field name="ip_allowlist"
                               placeholder="192.168.1.0/24&#10;10.0.0.1&#10;Leave blank to allow any IP"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Action ── -->
    <record id="action_mcp_api_key" model="ir.actions.act_window">
        <field name="name">API Keys</field>
        <field name="res_model">mcp.api.key</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first API key</p>
            <p>API keys authenticate inbound MCP requests from AI agents and tools.</p>
        </field>
    </record>

</odoo>
